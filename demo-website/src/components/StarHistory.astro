---
const STAR_CHART_URL =
  'https://api.star-history.com/chart?repos=brendangooden/ms-teams-sharepoint-downloader&type=date&legend=top-left';
const GH_URL =
  'https://github.com/brendangooden/ms-teams-sharepoint-downloader';
---
<section id="stars" class="hairline bg-bg-elev">
  <div class="mx-auto max-w-[1280px] px-6 lg:px-10 py-20 lg:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 mb-14">
      <div class="lg:col-span-4">
        <p class="section-num">07 / stars</p>
      </div>
      <div class="lg:col-span-8">
        <h2 class="section-title">
          People are <em>noticing.</em>
        </h2>
        <p class="mt-5 text-fg-dim text-[14px] leading-[1.65] max-w-2xl">
          Star history on GitHub &mdash; the only metric this project keeps.
          If the extension saved you time, a star helps others find it.
        </p>
      </div>
    </div>

    <img
      src={STAR_CHART_URL}
      alt="GitHub star history for brendangooden/ms-teams-sharepoint-downloader"
      loading="lazy"
      class="block mx-auto w-full max-w-3xl h-auto"
    />

    <div class="mt-6 flex flex-wrap items-center justify-between gap-3 text-[12px] text-fg-faint">
      <span>chart from <span class="kbd">star-history.com</span></span>
      <a
        href={GH_URL}
        target="_blank"
        rel="noopener"
        class="text-fg hover:text-red transition-colors"
      >
        star on github &rarr;
      </a>
    </div>
  </div>
</section>
