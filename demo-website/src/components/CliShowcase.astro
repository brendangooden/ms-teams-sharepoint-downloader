---
const tools = [
  {
    name: 'In-Browser',
    accent: 'purple',
    tag: 'recommended',
    formats: ['.mp4 (V+A)', '.m4a', '.mp4 (video-only)'],
    speed: 'sequential',
    needs: 'nothing',
    note: 'Default. SEA decryption built in. Best for anything under ~2GB.',
  },
  {
    name: 'ffmpeg',
    accent: 'red',
    tag: 'reliable',
    formats: ['.mp4', '.m4a · .mp3 · .wav'],
    speed: 'sequential',
    needs: 'ffmpeg installed',
    note: 'Ready-to-paste command. Best for MP3/WAV output.',
  },
  {
    name: 'yt-dlp',
    accent: 'red',
    tag: 'fastest',
    formats: ['.mp4', '.m4a · .mp3 · .wav'],
    speed: 'parallel ×16',
    needs: 'yt-dlp installed',
    note: 'Parallel segments. Best for hour-plus recordings.',
  },
];
---
<section id="cli" class="hairline bg-bg-elev">
  <div class="mx-auto max-w-[1280px] px-6 lg:px-10 py-20 lg:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 mb-14">
      <div class="lg:col-span-4">
        <p class="section-num">03 / for power users</p>
      </div>
      <div class="lg:col-span-8">
        <h2 class="section-title">
          Pick your tool. <em>Paste the command.</em>
        </h2>
        <p class="mt-6 max-w-xl text-fg-dim text-[14px]">
          For MP3, WAV, or the fastest possible download on long recordings,
          the extension generates the full command for ffmpeg or yt-dlp &mdash;
          auth header, manifest URL, and filename pre-filled.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 border border-border">
      {tools.map((tool) => (
        <div class="border-b md:border-b-0 md:border-r last:border-r-0 border-border p-6 flex flex-col">
          <div class="flex items-baseline justify-between mb-1">
            <h3 class={`font-display text-[1.5rem] leading-none ${tool.accent === 'red' ? 'text-red' : 'text-purple'}`}>{tool.name}</h3>
            <span class="text-[10px] uppercase tracking-[0.12em] text-fg-faint px-1.5 py-0.5 border border-border">{tool.tag}</span>
          </div>
          <p class="text-fg-dim text-[12.5px] mt-3 mb-5">{tool.note}</p>

          <dl class="text-[12px] mt-auto space-y-2 pt-4 border-t border-border">
            <div class="grid grid-cols-[5rem_1fr] gap-3">
              <dt class="text-fg-faint">formats</dt>
              <dd class="text-fg-dim">{tool.formats.join(' · ')}</dd>
            </div>
            <div class="grid grid-cols-[5rem_1fr] gap-3">
              <dt class="text-fg-faint">mode</dt>
              <dd class="text-fg-dim">{tool.speed}</dd>
            </div>
            <div class="grid grid-cols-[5rem_1fr] gap-3">
              <dt class="text-fg-faint">needs</dt>
              <dd class="text-fg-dim">{tool.needs}</dd>
            </div>
          </dl>
        </div>
      ))}
    </div>

    <p class="mt-6 text-[12px] text-fg-faint flex items-start gap-2">
      <span class="text-yellow shrink-0">!</span>
      <span>CLI commands embed a short-lived auth token &mdash; run promptly.</span>
    </p>
  </div>
</section>
