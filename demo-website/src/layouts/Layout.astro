---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
}

const {
  title = 'Teams Video & Transcript Exporter — download Teams recordings, SharePoint MP4s, and meeting transcripts',
  description = 'Chrome extension that downloads Microsoft Teams meeting recordings, SharePoint MP4s, and meeting transcripts straight from your browser — even when the Download button is greyed out, missing, or disabled by IT policy. Free, open source, MIT.',
  pathname = '/',
} = Astro.props;

const canonical = new URL(pathname, Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/og.png', Astro.site).toString()} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og.png', Astro.site).toString()} />

    <!-- Theme color reacts to OS preference -->
    <meta name="theme-color" content="#0b0b0d" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f5f1e6" media="(prefers-color-scheme: light)" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:ital,wght@0,300..700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD: SoftwareApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'Teams Video & Transcript Exporter',
      applicationCategory: 'BrowserApplication',
      operatingSystem: 'Chrome, Edge',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      url: canonical,
      description,
      author: { '@type': 'Person', name: 'Brendan Gooden' },
      license: 'https://opensource.org/licenses/MIT',
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>
